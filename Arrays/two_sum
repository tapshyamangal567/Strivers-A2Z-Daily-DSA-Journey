// Problem : Two sum
// Platform : Takeuforward
// TC :O(n)
// SC : (1)
// Difficulty : medium 

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        map<int , int>mpp;
        for(int i=0 ;i<nums.size() ;i++) {
            int rem = target - nums[i];
            if(mpp.find(rem) != mpp.end()) {
                return {mpp[rem] , i};

            }
            mpp[nums[i]] = i;
        }
    }
};
