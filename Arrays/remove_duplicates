// Problem : remove duplicates from sorted array
// Platform : Takeuforward
// Difficulty : Easy
// TC : O(N)
// SC : O(1)


class Solution {
    public int removeDuplicates(int[] nums) {
         int i=0;
         for(int j=1;j<nums.length;j++){
            if(nums[i] != nums[j]) {
                nums[i+1] = nums[j];
                i++;
            }
         }
         return i+1;
    }
}
