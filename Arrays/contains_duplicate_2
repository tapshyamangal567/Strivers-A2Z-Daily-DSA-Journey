// Problem : contains duplicate -2
// Platform : Takeuforward


class Solution {
public:
    bool containsNearbyDuplicate(vector<int>& nums, int k) {
        int i=0 , j=0;
       
        for(int i=0 ;i<nums.size();i++) {
            for(int j =0 ;j<nums.size();j++) {
                if(nums[i] == nums[j] && abs(i-j) <=k && i!=j) {
                    return true ;
                }
            }
        }
        return false ;
    }
};
