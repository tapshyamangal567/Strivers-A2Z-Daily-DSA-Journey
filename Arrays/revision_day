// Problem : Move zeros to end 

class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        int j = 0;

        // Place all non-zero elements at the front
        for (int i = 0; i < nums.size(); i++) {
            if (nums[i] != 0) {
                swap(nums[i], nums[j]);
                j++;
            }
        }
    }
};
