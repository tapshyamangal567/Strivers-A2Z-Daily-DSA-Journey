// Problem : Move zeros to the end of the array
// Platform : Takeuforward
// Difficulty : Easy
// TC : O(N)
// SC : O(1)

class Solution {
    public void moveZeroes(int[] nums) {
        int i=0;
        for(int j=1; j<nums.length ;j++) {
            if(nums[j] != 0) {
                int temp = nums[j];
                nums[j] = nums[i];
                nums[i] = temp;
                i++;
            }
        }
    }
}
