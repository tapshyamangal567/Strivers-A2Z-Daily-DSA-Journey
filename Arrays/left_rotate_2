// Problem : left roate an array by K places 
// TC : O(N+D)
// SC : O(1)
// Difficulty : easy

class Solution {
    public void rotateArray(int[] nums, int k) {
        
        int n = nums.length;
        reverse(nums,   nums+k);
        reverse(nums+k , nums+n);
        reverse(nums , nums+n);
    }
}
